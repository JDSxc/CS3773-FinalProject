function toggleMenu() {
  const menu = document.getElementById("menu");
  menu.style.display = menu.style.display === "none" ? "block" : "none";
}
</script>



discount code input

<input type="text" id="discountCode" placeholder="Enter code" />
<button onclick="applyDiscount()">Apply</button>

<p id="discountMsg"></p>

<script>
async function applyDiscount() {
  const code = document.getElementById("discountCode").value;

  const res = await fetch("/api/discount/apply", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({ code })
  });

  const data = await res.json();

  document.getElementById("discountMsg").innerText =
    data.success ? "Discount applied!" : "Invalid code";

  loadCart();
}
</script>



checkout with tax

<div id="summary"></div>

<script>
function renderSummary(cart) {
  let subtotal = 0;

  cart.forEach(item => {
    subtotal += item.price * item.qty;
  });

  const tax = subtotal * 0.0825;
  const total = subtotal + tax;

  document.getElementById("summary").innerHTML = `
    Subtotal: $${subtotal.toFixed(2)} <br>
    Tax (8.25%): $${tax.toFixed(2)} <br>
    Total: $${total.toFixed(2)}
  `;
}
</script>



add/edit/delete products

<button onclick="addProduct()">Add Product</button>

<script>
async function addProduct() {
  const name = prompt("Product name:");
  const price = prompt("Price:");

  await fetch("/api/admin/add", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({ name, price })
  });

  alert("Product added");
}

async function deleteProduct(id) {
  await fetch("/api/admin/delete", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({ id })
  });

  alert("Deleted");
}
</script>